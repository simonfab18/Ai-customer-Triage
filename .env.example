# Shared local development settings
APP_ENV=local

# Backend
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
DATABASE_URL=sqlite:///./support_triage.db

# Redis and worker
REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false

# Observability and operations
LOGGING_LEVEL=INFO
SERVICE_NAME=api
RELEASE_VERSION=0.1.0
OPERATIONS_ALERT_OWNER=platform
OPERATIONS_INTERNAL_TOKEN=
OPERATIONS_RUNBOOK_BASE_URL=
OPERATIONS_FAILURE_ALERT_THRESHOLD=3

# Security and rate limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_LIMIT=120
RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
RATE_LIMIT_SENSITIVE_LIMIT=10
RATE_LIMIT_SENSITIVE_WINDOW_SECONDS=60
MAX_REQUEST_BODY_BYTES=1048576

# Security
ENCRYPTION_KEY=dev-only-change-me
ENCRYPTION_KEY_VERSION=1

# M7 pilot release controls
PILOT_REQUIRE_ALLOWLIST=false
PILOT_ALLOWLISTED_ORGANIZATION_IDS=
PILOT_SYNC_ENABLED=true
PILOT_AUTO_TRIAGE_ENABLED=true
PILOT_DRAFT_CREATION_ENABLED=true

