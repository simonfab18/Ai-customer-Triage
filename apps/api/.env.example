APP_NAME=AI Customer Support Triage API
APP_ENV=local
DEBUG=true

API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
LOGGING_LEVEL=INFO
ERROR_TRACKING_DSN=

REDIS_URL=redis://redis:6379/0
CELERY_TASK_ALWAYS_EAGER=false
WORKER_CONCURRENCY=2
SYNC_FALLBACK_INTERVAL_MINUTES=15
WATCH_RENEWAL_SCHEDULE=0 3 * * *

# Local default. Replace with the Supabase Session Pooler URL in staging/production.
DATABASE_URL=sqlite:///./support_triage.db
# DATABASE_URL=postgresql+psycopg://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[REGION].pooler.supabase.com:5432/postgres

# Generate a strong value locally with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ENCRYPTION_KEY=dev-only-change-me

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=

# Server-only. Never expose in frontend env files or commit real values.
SUPABASE_SECRET_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/gmail/oauth/callback

# Required in staging/production before Gmail push sync milestones are enabled.
GOOGLE_CLOUD_PROJECT_ID=customer-support-triage-501408
GOOGLE_PUBSUB_TOPIC=projects/customer-support-triage-501408/topics/gmail-notifications
GOOGLE_PUBSUB_SUBSCRIPTION=gmail-notifications-sub
PUBSUB_EXPECTED_AUDIENCE=https://ai-customer-support-triage-response.onrender.com/v1/webhooks/google/gmail
PUBSUB_SERVICE_ACCOUNT_EMAIL=pub-sub-push-invoker@customer-support-triage-501408.iam.gserviceaccount.com

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Local fallback only. Keep false in staging/production; use JWKS or SUPABASE_JWT_SECRET instead.
AUTH_ALLOW_UNVERIFIED_JWT=false
